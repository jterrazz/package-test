{
    "name": "@jterrazz/test",
    "version": "9.2.0",
    "description": "Declarative testing framework for HTTP APIs, CLIs, and background jobs — one entry point, real infrastructure, golden-file assertions, plus an oxlint convention plugin.",
    "keywords": [
        "api-testing",
        "cli-testing",
        "e2e",
        "golden-files",
        "hexagonal",
        "integration-testing",
        "msw",
        "oxlint",
        "test-framework",
        "testcontainers",
        "testing",
        "vitest"
    ],
    "license": "MIT",
    "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/jterrazz/package-test"
    },
    "bin": {
        "jterrazz-test-check": "dist/checker.js"
    },
    "files": [
        "dist",
        "!dist/catalog.*"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./oxlint": {
            "types": "./dist/oxlint.d.ts",
            "import": "./dist/oxlint.js",
            "require": "./dist/oxlint.cjs"
        }
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "docs": "npm run build && node dist/catalog.js && typescript docs",
        "lint": "typescript check && node dist/checker.js specs",
        "lint:fix": "typescript fix",
        "test": "vitest --run"
    },
    "dependencies": {
        "better-sqlite3": "^12.11.1",
        "mockdate": "^3.0.5",
        "msw": "^2.15.0",
        "pg": "^8.22.0",
        "redis": "^6.1.0",
        "testcontainers": "^12.0.4",
        "vitest-mock-extended": "^5.0.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@hono/node-server": "^2.0.8",
        "@jterrazz/typescript": "^7.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^26.1.1",
        "@types/pg": "^8.20.0",
        "hono": "^4.12.30",
        "oxlint": "^1.74.0",
        "playwright": "^1.49.0",
        "tsdown": "^0.22.7",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "playwright": "^1.49.0",
        "vitest": "^4.1.10"
    },
    "peerDependenciesMeta": {
        "playwright": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=20"
    }
}
