{
    "name": "@jterrazz/test",
    "version": "8.0.0",
    "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/jterrazz/package-test"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./services": {
            "require": "./dist/services.cjs",
            "import": "./dist/services.js"
        },
        "./mock": {
            "require": "./dist/mock.cjs",
            "import": "./dist/mock.js"
        },
        "./intercept": {
            "require": "./dist/intercept.cjs",
            "import": "./dist/intercept.js"
        }
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "docs": "typescript docs",
        "lint": "typescript check",
        "lint:fix": "typescript fix",
        "test": "vitest --run"
    },
    "dependencies": {
        "better-sqlite3": "^12.11.1",
        "mockdate": "^3.0.5",
        "pg": "^8.22.0",
        "redis": "^6.1.0",
        "testcontainers": "^12.0.4",
        "vitest-mock-extended": "^5.0.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@hono/node-server": "^2.0.8",
        "@jterrazz/typescript": "^6.1.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^26.1.1",
        "@types/pg": "^8.20.0",
        "hono": "^4.12.30",
        "msw": "^2.15.0",
        "tsdown": "^0.22.7",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "hono": "^4.12.30",
        "msw": "^2.15.0",
        "vitest": "^4.1.10"
    },
    "peerDependenciesMeta": {
        "hono": {
            "optional": true
        },
        "msw": {
            "optional": true
        }
    }
}
